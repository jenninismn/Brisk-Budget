{
  "name": "personal-money",
  "version": "1.0.0",
  "description": "Brisk Budget - A lightweight personal finance management web application",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:pipeline": "node scripts/run-test-pipeline.js",
    "test:load:threshold": "docker compose --profile test run --rm loadtest run /scripts/categories-threshold.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ]
  },
  "keywords": [
    "personal-finance",
    "budget",
    "budgeting",
    "finance-tracker",
    "money-management",
    "expense-tracker",
    "accounting",
    "financial-planning",
    "household-budget",
    "pwa"
  ],
  "author": "Ethan Copping",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "jest": "^30.4.2",
    "playwright": "^1.61.0",
    "supertest": "^7.2.2"
  }
}
